# ═══════════════════════════════════════════════════════════════════
#  Hotel PMS v3 — Backend Environment Variables
#  Copy to .env and fill in your values.
#  Never commit .env to source control.
# ═══════════════════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins
# Dev:     http://localhost:3000
# Staging: https://staging.your-domain.com
# Prod:    https://your-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────
# Option A — individual params (dev / docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hotel_pms
DB_USER=postgres
DB_PASSWORD=postgres123

# Option B — connection URL (staging / production — overrides individual params)
# DATABASE_URL=postgresql://user:pass@host:5432/hotel_pms?sslmode=require

# Connection pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# Set to 'true' to log every SQL query (dev only)
DB_DEBUG=false

# ── JWT ──────────────────────────────────────────────────────────────
# REQUIRED in production: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING_HERE_FOR_PRODUCTION
JWT_EXPIRES_IN=8h

# ── GST ──────────────────────────────────────────────────────────────
GST_ROOM_RATE=12

# ── Hotel branding (fallback when tenant/property record is missing) ─
HOTEL_NAME=Grand Palace Hotel
HOTEL_ADDRESS=123 MG Road, Mysuru, Karnataka 570001
HOTEL_PHONE=+91 821 234 5678
HOTEL_EMAIL=info@grandpalace.com
HOTEL_GSTIN=29AABCU9603R1ZX
HOTEL_LOGO_URL=

# ── Email (optional — SMTP for booking confirmations) ────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@hotel.com

# ── Storage ─────────────────────────────────────────────────────────
# 'local' = filesystem  |  's3' = AWS S3
STORAGE_DRIVER=local
S3_BUCKET=
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Payment (stub — expand when integrating Razorpay/Stripe) ─────────
PAYMENT_PROVIDER=none
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── pgAdmin (Docker Compose only) ───────────────────────────────────
PGADMIN_EMAIL=admin@hotel.com
PGADMIN_PASSWORD=admin
