{
  "name": "hotel-pms-backend",
  "version": "3.0.0",
  "description": "Hotel PMS REST API — v3 with Multi-Property, RBAC, ES Modules",
  "main": "src/server.js",
  "type": "module",
"scripts": {
  "dev": "nodemon --watch src --ext js src/server.js",
  "start": "node src/server.js",

  "migrate": "knex migrate:latest --knexfile knexfile.cjs",
  "migrate:rollback": "knex migrate:rollback --knexfile knexfile.cjs",
  "migrate:make": "knex migrate:make --knexfile knexfile.cjs",

  "seed": "knex seed:run --knexfile knexfile.cjs",

  "db:reset": "npm run migrate:rollback && npm run migrate && npm run seed",

  "db:fresh": "knex migrate:rollback --all --knexfile knexfile.cjs && npm run migrate && npm run seed"
},
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
